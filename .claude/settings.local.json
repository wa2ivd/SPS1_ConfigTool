{
  "permissions": {
    "allow": [
      "PowerShell(python --version)",
      "PowerShell(py --version)",
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(npm uninstall serialport)",
      "PowerShell(Get-CimInstance Win32_SerialPort)",
      "PowerShell(Get-PnpDevice -Class Ports -PresentOnly -ErrorAction SilentlyContinue)",
      "PowerShell(\"---\")",
      "Bash(node --check src/renderer.js)",
      "Bash(node --check src/index.js)",
      "Bash(node --check src/preload.js)",
      "Bash(node --check docs/app.js)"
    ]
  }
}
